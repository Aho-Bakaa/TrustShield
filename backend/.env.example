# Copy to `.env` and fill ONE provider key. If none is set, TrustShield runs in
# rule-based mock mode (still fully functional for the demo).

# Which provider to use: groq | openrouter | gemini
LLM_PROVIDER=groq

# Set the key for the provider you chose (only one needed):
GROQ_API_KEY=
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=

# Vision model for screenshot/image analysis (independent of the text model).
# Default is Groq llama-4-scout -> works with the GROQ_API_KEY above, no extra key needed.
# (Alternative: LLM_VISION_MODEL=gemini/gemini-2.5-flash  — then set GEMINI_API_KEY)
# LLM_VISION_MODEL=groq/meta-llama/llama-4-scout-17b-16e-instruct

# Optional: override the model (else a sensible default per provider is used)
# LLM_MODEL=groq/llama-3.3-70b-versatile
# LLM_MODEL=gemini/gemini-2.0-flash
# LLM_MODEL=openrouter/meta-llama/llama-3.3-70b-instruct

# Rendering / network
RENDER_ENABLED=true        # use Playwright; falls back to HTTP fetch if browser missing
NETWORK_ENABLED=true       # master switch; set false for fully offline runs

# CORS (frontend origin)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
